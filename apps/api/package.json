{
  "name": "@apps/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "dev": "bun --watch run src/Main.ts",
    "migrate": "bun run src/Infrastructure/Database/Migrate.ts",
    "start": "bun run src/Main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@app/api-core": "workspace:*",
    "@effect/ai-openrouter": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/sql-pg": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@tooling/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
