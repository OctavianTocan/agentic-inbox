# Postgres — matches docker-compose.yml (POSTGRES_USER / _PASSWORD / _DB).
# Host port defaults to 5442 (override with DB_PORT in docker-compose).
DATABASE_URL=postgres://cogram:cogram@localhost:5442/cogram

# OpenRouter — LLM provider for the triage + chat agent.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.5

# apps/api HTTP port.
PORT=8001
