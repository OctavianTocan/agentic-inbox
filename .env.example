# --- Postgres ---
# Local: matches docker-compose.yml (POSTGRES_USER / _PASSWORD / _DB).
# Host port defaults to 5442 (override with DB_PORT in docker-compose).
# Vercel / production runtime: set DATABASE_URL to Neon’s pooled / serverless
# URL. For one-shot migrate (`bun run --cwd apps/api migrate`), use Neon’s
# direct (non-pooler) URL instead — do not migrate through the pooler.
DATABASE_URL=postgres://agentic_inbox:agentic_inbox@localhost:5442/agentic_inbox

# Dedicated database for the api test suite, which truncates every table between
# cases. Defaults to `agentic_inbox_test` (auto-created by docker/postgres-init); it must
# be a distinct `*_test` database, never DATABASE_URL.
# Local-only — do not set TEST_DATABASE_URL on Vercel.
TEST_DATABASE_URL=postgres://agentic_inbox:agentic_inbox@localhost:5442/agentic_inbox_test

# --- OpenRouter (required with DATABASE_URL for live triage + chat) ---
# If either DATABASE_URL or OPENROUTER_API_KEY is unset, the app runs in demo
# mode (seeded showcase inbox + sticker). Set both for the live agent.
# Set OPENROUTER_API_KEY in the Vercel Dashboard (Production + Preview).
# Prefer a model that lists `response_format` / structured outputs on
# https://openrouter.ai/models — triage uses OpenRouter json_schema strict mode.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.5

# --- Batch triage pacing (keeps free OpenRouter keys under ≈20 RPM) ---
# How many emails to triage at once (default 1). Raise only if you have headroom.
# TRIAGE_CONCURRENCY=1
# Pause between emails in ms (default 2000; set 0 to disable).
# TRIAGE_GAP_MS=2000

# --- Local web / standalone API only (not used on Vercel after Step 6 fold) ---
# After the API is folded into Next, AGENTIC_INBOX_API_ORIGIN is optional and
# local-only (proxy target for a separate `bun run dev:api` process). Do not set
# it on Vercel.
AGENTIC_INBOX_API_ORIGIN=http://127.0.0.1:8001
WEB_PORT=3003
PORT=8001
