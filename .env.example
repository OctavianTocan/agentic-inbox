# Postgres — matches docker-compose.yml (POSTGRES_USER / _PASSWORD / _DB).
# Host port defaults to 5442 (override with DB_PORT in docker-compose).
DATABASE_URL=postgres://agentic_inbox:agentic_inbox@localhost:5442/agentic_inbox

# Dedicated database for the api test suite, which truncates every table between
# cases. Defaults to `agentic_inbox_test` (auto-created by docker/postgres-init); it must
# be a distinct `*_test` database, never DATABASE_URL.
TEST_DATABASE_URL=postgres://agentic_inbox:agentic_inbox@localhost:5442/agentic_inbox_test

# apps/web -> apps/api proxy target. Use the API origin only; `/api/v1` is added by Next rewrites.
AGENTIC_INBOX_API_ORIGIN=http://127.0.0.1:8001
WEB_PORT=3003

# OpenRouter — LLM provider for the triage + chat agent.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.5

# apps/api HTTP port.
PORT=8001
