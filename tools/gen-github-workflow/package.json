{
  "name": "gen-github-workflow",
  "version": "0.1.0",
  "description": "Generate GitHub Actions workflows from YAML fragments embedded in source files",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "bun run src/index.ts generate",
    "check": "bun run src/index.ts check",
    "e2e-test": "bun run src/index.ts e2e-test"
  },
  "devDependencies": {
    "@tooling/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  }
}
