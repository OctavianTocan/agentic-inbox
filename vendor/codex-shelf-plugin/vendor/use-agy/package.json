{
  "name": "use-agy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/agent-dev/*",
      "packages/ci/*",
      "packages/ci/actions/*",
      "packages/tooling/*",
      "packages/use-agy/*"
    ],
    "catalog": {
      "@effect/platform-bun": "4.0.0-beta.85",
      "@effect/vitest": "4.0.0-beta.85",
      "@types/bun": "^1.3.12",
      "effect": "4.0.0-beta.85",
      "typescript": "^5.9.3",
      "vitest": "^4.1.9",
      "yaml": "^2.8.1"
    }
  },
  "scripts": {
    "check": "biome check .",
    "format": "biome format --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "vitest run",
    "knip": "knip",
    "ci": "biome check . && bun run typecheck && vitest run && knip && bun run skill-gen:check && bun run workflow-gen:check",
    "skill-gen:generate": "bun run packages/ci/skill-gen/src/index.ts generate",
    "skill-gen:check": "bun run packages/ci/skill-gen/src/index.ts check",
    "skill-gen:e2e-test": "bun run packages/ci/skill-gen/src/index.ts e2e-test",
    "workflow-gen:generate": "bun run packages/ci/workflow-gen/src/index.ts generate",
    "workflow-gen:check": "bun run packages/ci/workflow-gen/src/index.ts check",
    "workflow-gen:e2e-test": "bun run packages/ci/workflow-gen/src/index.ts e2e-test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "effect": "catalog:",
    "knip": "^6.17.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "packageManager": "bun@1.3.14"
}
