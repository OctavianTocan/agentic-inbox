{
  "name": "{{REPO_NAME}}",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*/*",
      "packages/ci/actions/*"
    ],
    "catalog": {
      "@effect/platform-bun": "{{EFFECT_VERSION}}",
      "@effect/vitest": "{{EFFECT_VERSION}}",
      "@types/bun": "^{{BUN_TYPES_VERSION}}",
      "effect": "{{EFFECT_VERSION}}",
      "typescript": "^{{TS_VERSION}}",
      "vitest": "^{{VITEST_VERSION}}",
      "yaml": "^2.8.1"
    }
  },
  "scripts": {
    "check": "biome check .",
    "format": "biome format --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "vitest run",
    "knip": "knip",
    "ci": "biome check . && bun run typecheck && vitest run && knip && bun run skill-gen:check && bun run workflow-gen:check",
    "skill-gen:generate": "bun run packages/ci/skill-gen/src/index.ts generate",
    "skill-gen:check": "bun run packages/ci/skill-gen/src/index.ts check",
    "skill-gen:e2e-test": "bun run packages/ci/skill-gen/src/index.ts e2e-test",
    "workflow-gen:generate": "bun run packages/ci/workflow-gen/src/index.ts generate",
    "workflow-gen:check": "bun run packages/ci/workflow-gen/src/index.ts check",
    "workflow-gen:e2e-test": "bun run packages/ci/workflow-gen/src/index.ts e2e-test"
  },
  "devDependencies": {
    "@biomejs/biome": "{{BIOME_VERSION}}",
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "effect": "catalog:",
    "knip": "^{{KNIP_VERSION}}",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": ">={{BUN_VERSION}}"
  },
  "packageManager": "bun@{{BUN_VERSION}}"
}
