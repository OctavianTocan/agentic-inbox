{
  "name": "agentic-inbox",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/**/*",
    "tools/openapi-gen",
    "tools/project-structure-gen",
    "tools/skill-gen",
    "tools/gen-github-workflow"
  ],
  "catalog": {
    "@base-ui/react": "^1.6.0",
    "@biomejs/biome": "2.5.3",
    "@effect/ai-openrouter": "4.0.0-beta.93",
    "@effect/platform-bun": "4.0.0-beta.93",
    "@effect/platform-node": "4.0.0-beta.93",
    "@effect/platform-node-shared": "4.0.0-beta.93",
    "@effect/sql-pg": "4.0.0-beta.93",
    "@effect/language-service": "^0.86.6",
    "@effect/vitest": "4.0.0-beta.93",
    "@colbymchenry/codegraph": "^1.4.0",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/redaction": "^5.2.5",
    "@fontsource/redaction-70": "^5.2.5",
    "@hookform/resolvers": "^5.4.0",
    "@pierre/diffs": "^1.2.12",
    "@shadcn/react": "^0.2.1",
    "@shikijs/themes": "^4.3.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-table": "^8.21.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@google/design.md": "^0.3.0",
    "@types/bun": "^1.3.14",
    "@types/hast": "3.0.4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "effect": "4.0.0-beta.93",
    "embla-carousel-react": "^8.6.0",
    "fumadocs-core": "^16.11.2",
    "hast": "^1.0.0",
    "hast-util-sanitize": "^5.0.2",
    "input-otp": "^1.4.2",
    "jsdom": "29.1.1",
    "katex": "^0.17.0",
    "lefthook": "2.1.10",
    "lucide-react": "^1.24.0",
    "marked": "^18.0.6",
    "mermaid": "^11.16.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "openapi-types": "^12.1.3",
    "postcss-load-config": "6.0.1",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.1",
    "recharts": "^3.9.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math-extended": "^6.1.0",
    "remend": "^1.3.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "use-stick-to-bottom": "^1.1.6",
    "vaul-base": "^1.0.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "scripts": {
    "dev": "cd apps/web && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "dev:api": "cd apps/api && bun run dev",
    "build": "cd apps/web && bun run build",
    "start": "cd apps/web && bun run start",
    "test": "vitest run --passWithNoTests",
    "typecheck": "bun run typecheck:web && bun run typecheck:api && bun run typecheck:api-core && bun run typecheck:openapi-gen && bun run typecheck:structure-gen && bun run typecheck:skill-gen && bun run typecheck:workflow-gen",
    "typecheck:web": "cd apps/web && bun run typecheck",
    "typecheck:api": "cd apps/api && bun run typecheck",
    "typecheck:api-core": "cd packages/api-core && bun run typecheck",
    "typecheck:openapi-gen": "cd tools/openapi-gen && bun run typecheck",
    "typecheck:structure-gen": "cd tools/project-structure-gen && bun run typecheck",
    "typecheck:skill-gen": "cd tools/skill-gen && bun run typecheck",
    "typecheck:workflow-gen": "cd tools/gen-github-workflow && bun run typecheck",
    "lint": "biome check .",
    "format": "biome check --write .",
    "codegraph:init": "codegraph init",
    "codegraph:index": "codegraph index",
    "codegraph:install": "codegraph install",
    "design:lint": "designmd lint DESIGN.md",
    "deps:check": "bunx npm-check-updates --workspaces",
    "deps:update": "bunx npm-check-updates -u --workspaces",
    "deps:check:effect": "bunx npm-check-updates --workspaces --filter 'effect|@effect/ai-openrouter|@effect/platform-bun|@effect/platform-node|@effect/sql-pg|@effect/vitest' --target '@beta'",
    "deps:update:effect": "bunx npm-check-updates -u --workspaces --filter 'effect|@effect/ai-openrouter|@effect/platform-bun|@effect/platform-node|@effect/sql-pg|@effect/vitest' --target '@beta'",
    "skills:generate": "bun run tools/skill-gen/src/index.ts generate --base . --output .agent/skills",
    "skills:check": "bun run tools/skill-gen/src/index.ts check --base . --output .agent/skills",
    "workflows:generate": "bun run tools/gen-github-workflow/src/index.ts generate --base tools/workflow-fragments --output .github/workflows && bun run tools/workflow-fragments/sync-required.ts generate",
    "workflows:check": "bun run tools/gen-github-workflow/src/index.ts check --base tools/workflow-fragments --output .github/workflows && bun run tools/workflow-fragments/sync-required.ts check",
    "structure:generate": "bun run tools/project-structure-gen/src/index.ts generate",
    "structure:check": "bun run tools/project-structure-gen/src/index.ts check",
    "openapi:generate": "bun run tools/openapi-gen/src/index.ts generate",
    "openapi:check": "bun run tools/openapi-gen/src/index.ts check",
    "emails:sync": "bun run apps/api/scripts/sync-emails-dataset.ts",
    "emails:check": "bun run emails:sync && git diff --exit-code -- apps/api/src/Modules/Emails/emails.dataset.ts",
    "generate": "bun run skills:generate && bun run workflows:generate && bun run structure:generate && bun run openapi:generate && bun run emails:sync",
    "check:generated:portable": "bun run workflows:check && bun run openapi:check && bun run emails:check",
    "check:generated": "bun run check:generated:portable && bun run skills:check && bun run structure:check",
    "ci": "bun run design:lint && bun run lint && bun run check:generated:portable && bun run typecheck && bun run test",
    "arch:sentrux": "sentrux gate .",
    "react:doctor": "bunx react-doctor@latest --no-telemetry --root apps/web",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@effect/platform-node": "catalog:",
    "@google/design.md": "catalog:",
    "effect": "catalog:",
    "lefthook": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "yaml": "catalog:"
  },
  "overrides": {
    "@effect/ai-openrouter": "4.0.0-beta.93",
    "@effect/platform-bun": "4.0.0-beta.93",
    "@effect/platform-node": "4.0.0-beta.93",
    "@effect/platform-node-shared": "4.0.0-beta.93",
    "@effect/sql-pg": "4.0.0-beta.93",
    "@effect/vitest": "4.0.0-beta.93",
    "@types/hast": "3.0.4",
    "effect": "4.0.0-beta.93"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "lefthook",
    "sharp",
    "unrs-resolver"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "patchedDependencies": {
    "next-themes@0.4.6": "patches/next-themes@0.4.6.patch"
  }
}
